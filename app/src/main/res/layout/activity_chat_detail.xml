<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/map_bg"
    tools:context=".activities.MessagesActivity">

    <!-- dark overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#C9000000" />

    <!-- main black panel -->
    <LinearLayout
        android:id="@+id/mainPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="18dp"
        android:background="#DD000000"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="60dp">

            <ImageButton
                android:id="@+id/backBtn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_centerVertical="true"
                android:background="@drawable/round_dark_button_bg"
                android:contentDescription="Back"
                android:padding="10dp"
                android:src="@drawable/ic_back_custom" />

            <ImageView
                android:id="@+id/profileImgTop"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/backBtn"
                android:layout_marginStart="16dp"
                android:scaleType="centerCrop"
                android:src="@drawable/profile2" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/profileImgTop"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ram Rai"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active Now"
                        android:textColor="#B6B6B6"
                        android:textSize="11sp" />

                    <View
                        android:layout_width="7dp"
                        android:layout_height="7dp"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/dot" />
                </LinearLayout>
            </LinearLayout>
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            android:background="#1FFFFFFF" />

        <!-- chat area -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- message 1 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="top">

                    <FrameLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="bottom|start"
                            android:scaleType="centerCrop"
                            android:src="@drawable/profile2" />

                        <View
                            android:layout_width="7dp"
                            android:layout_height="7dp"
                            android:layout_gravity="top|end"
                            android:background="@drawable/dot" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/chat_bubble_dark"
                        android:paddingStart="16dp"
                        android:paddingTop="12dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="12dp"
                        android:text="Are you still travelling?"
                        android:textColor="#8F8F8F"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- message 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="end"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/chat_bubble_teal"
                        android:paddingStart="18dp"
                        android:paddingTop="12dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="12dp"
                        android:text="Yes, i’m at Istanbul.."
                        android:textColor="#D7FFFF"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="✓✓ 3:00PM"
                        android:textColor="#3EA8FF"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- message 3 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:layout_marginStart="54dp"
                    android:background="@drawable/chat_bubble_dark"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp"
                    android:text="OoOo, Thats so Cool!"
                    android:textColor="#5F5F5F"
                    android:textSize="14sp" />

                <!-- message 4 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal"
                    android:gravity="top">

                    <FrameLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="bottom|start"
                            android:scaleType="centerCrop"
                            android:src="@drawable/profile2" />

                        <View
                            android:layout_width="7dp"
                            android:layout_height="7dp"
                            android:layout_gravity="top|end"
                            android:background="@drawable/dot" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/chat_bubble_dark"
                        android:paddingStart="16dp"
                        android:paddingTop="12dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="12dp"
                        android:text="Raining??"
                        android:textColor="#5F5F5F"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- voice bubble teal -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="end"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="175dp"
                        android:layout_height="54dp"
                        android:background="@drawable/chat_bubble_teal"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="18dp"
                        android:paddingEnd="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="⋯⋯⋯⋯⋯"
                            android:textColor="#00E6FF"
                            android:textSize="16sp" />

                        <ImageView
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="@drawable/voice_play_circle_bg"
                            android:padding="8dp"
                            android:src="@android:drawable/ic_media_play" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="✓✓ 9:00AM"
                        android:textColor="#3EA8FF"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- date -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="22dp"
                    android:text="Thursday 24, 2022"
                    android:textColor="#9A9A9A"
                    android:textSize="14sp" />

                <!-- message 5 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:layout_marginStart="54dp"
                    android:background="@drawable/chat_bubble_dark"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp"
                    android:text="Hi, Did you heared?"
                    android:textColor="#5F5F5F"
                    android:textSize="14sp" />

                <!-- voice bubble black -->
                <LinearLayout
                    android:layout_width="195dp"
                    android:layout_height="54dp"
                    android:layout_marginTop="18dp"
                    android:layout_marginStart="54dp"
                    android:background="@drawable/chat_bubble_dark"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="10dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/voice_pause_circle_bg"
                        android:padding="8dp"
                        android:src="@android:drawable/ic_media_pause" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:text="|||||||||||||||||||||"
                        android:textColor="#D9D9D9"
                        android:textSize="16sp" />
                </LinearLayout>

                <!-- message 6 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal"
                    android:gravity="top">

                    <FrameLayout
                        android:layout_width="42dp"
                        android:layout_height="42dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="bottom|start"
                            android:scaleType="centerCrop"
                            android:src="@drawable/profile2" />

                        <View
                            android:layout_width="7dp"
                            android:layout_height="7dp"
                            android:layout_gravity="top|end"
                            android:background="@drawable/dot" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/chat_bubble_dark"
                        android:paddingStart="16dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="10dp"
                        android:text="Ok!"
                        android:textColor="#5F5F5F"
                        android:textSize="14sp" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="#1FFFFFFF" />

        <!-- bottom bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/round_dark_button_bg"
                android:contentDescription="Attach"
                android:padding="9dp"
                android:src="@drawable/ic_attach_custom" />

            <EditText
                android:id="@+id/messageEditText"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@drawable/chat_input_bg"
                android:hint="Send Message"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@android:color/white"
                android:textColorHint="#8B8B8B"
                android:textSize="16sp" />

            <ImageButton
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:contentDescription="Send"
                android:padding="6dp"
                android:src="@drawable/ic_send_custom" />

            <ImageButton
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/mic_circle_bg"
                android:contentDescription="Mic"
                android:padding="12dp"
                android:src="@android:drawable/ic_btn_speak_now" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>