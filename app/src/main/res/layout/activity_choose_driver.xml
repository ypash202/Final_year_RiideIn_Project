<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.ChooseDriverActivity">

    <ImageView
        android:id="@+id/mapBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/map_bg" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000" />

    <TextView
        android:id="@+id/toMapText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="68dp"
        android:layout_marginEnd="72dp"
        android:background="@drawable/round_dark_button_bg"
        android:ellipsize="end"
        android:maxLines="1"
        android:maxWidth="150dp"
        android:paddingStart="12dp"
        android:paddingTop="7dp"
        android:paddingEnd="12dp"
        android:paddingBottom="7dp"
        android:text="Destination"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:textStyle="bold" />

    <View
        android:layout_width="62dp"
        android:layout_height="62dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="92dp"
        android:layout_marginEnd="110dp"
        android:background="@drawable/round_dark_button_bg"
        android:alpha="0.35" />

    <View
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginStart="178dp"
        android:layout_marginTop="178dp"
        android:background="@drawable/round_dark_button_bg"
        android:alpha="0.35" />

    <TextView
        android:id="@+id/fromMapText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="145dp"
        android:layout_marginTop="254dp"
        android:background="@drawable/round_dark_button_bg"
        android:ellipsize="end"
        android:maxLines="1"
        android:maxWidth="170dp"
        android:paddingStart="12dp"
        android:paddingTop="7dp"
        android:paddingEnd="12dp"
        android:paddingBottom="7dp"
        android:text="Current Location"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:textStyle="bold" />

    <View
        android:layout_width="4dp"
        android:layout_height="44dp"
        android:layout_marginTop="118dp"
        android:layout_marginStart="266dp"
        android:background="#63B7C4" />

    <View
        android:layout_width="4dp"
        android:layout_height="56dp"
        android:layout_marginTop="161dp"
        android:layout_marginStart="265dp"
        android:rotation="84"
        android:background="#63B7C4" />

    <View
        android:layout_width="4dp"
        android:layout_height="46dp"
        android:layout_marginTop="198dp"
        android:layout_marginStart="237dp"
        android:background="#63B7C4" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="18dp">

        <Button
            android:id="@+id/cancelRequestButton"
            android:layout_width="170dp"
            android:layout_height="42dp"
            android:background="@drawable/cancel_request_button_bg"
            android:text="✕ Cancel request"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/chooseDriverTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Choose a driver"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/driverCard1"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/choose_driver_card_bg"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/profile1" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/driver1NameText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Binod"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/driver1VehicleText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MOTOR-BIKE Honda"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/driver1PriceText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rs 200"
                        android:textColor="@android:color/white"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/driver1TimeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 min"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/acceptButton1"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="16dp"
                    android:layout_weight="1"
                    android:background="@drawable/accept_button_bg"
                    android:text="Accept"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/declineButton1"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/decline_button_bg"
                    android:text="Decline"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/driverCard2"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/choose_driver_card_bg"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/profile2" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/driver2NameText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sulav"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/driver2VehicleText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MOTOR-BIKE Bajaj"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/driver2PriceText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rs 200"
                        android:textColor="@android:color/white"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/driver2TimeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2 min"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/acceptButton2"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="16dp"
                    android:layout_weight="1"
                    android:background="@drawable/accept_button_bg"
                    android:text="Accept"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/declineButton2"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/decline_button_bg"
                    android:text="Decline"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</FrameLayout>