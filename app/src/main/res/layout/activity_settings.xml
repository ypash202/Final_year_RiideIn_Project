<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.SettingsActivity">

    <ImageView
        android:id="@+id/mapBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/map_bg" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="34dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="@drawable/round_dark_button_bg"
                android:contentDescription="@string/back"
                android:padding="12dp"
                android:src="@drawable/ic_back_custom"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/settings"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/deleteButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/round_dark_button_bg"
                android:contentDescription="@string/delete"
                android:padding="12dp"
                android:src="@drawable/ic_delete_custom"
                app:tint="@android:color/white" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="42dp" />

        <LinearLayout
            android:id="@+id/settingsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#D9000000"
            android:orientation="vertical">

            <!-- My Account -->
            <RelativeLayout
                android:id="@+id/itemMyAccount"
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/iconMyAccount"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_centerVertical="true"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_my_account_custom" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/iconMyAccount"
                    android:layout_toStartOf="@id/arrowMyAccount"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/my_account"
                        android:textColor="@android:color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/my_account_desc"
                        android:textColor="#8A8A8A"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/arrowMyAccount"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/round_dark_button_bg"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:padding="14dp"
                    android:src="@drawable/ic_chevron_right_custom"
                    app:tint="@android:color/white" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#14FFFFFF" />

            <!-- Security -->
            <RelativeLayout
                android:id="@+id/itemSecurity"
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/iconSecurity"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_centerVertical="true"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_teal_ticket" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/iconSecurity"
                    android:layout_toStartOf="@id/arrowSecurity"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/security"
                        android:textColor="@android:color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/settings_coupon_desc"
                        android:textColor="#8A8A8A"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/arrowSecurity"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/round_dark_button_bg"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:padding="14dp"
                    android:src="@drawable/ic_chevron_right_custom"
                    app:tint="@android:color/white" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#14FFFFFF" />

            <!-- Language -->
            <RelativeLayout
                android:id="@+id/itemLanguage"
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/iconLanguage"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_centerVertical="true"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_teal_ticket" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/iconLanguage"
                    android:layout_toStartOf="@id/arrowLanguage"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/language"
                        android:textColor="@android:color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/settings_coupon_desc"
                        android:textColor="#8A8A8A"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/arrowLanguage"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/round_dark_button_bg"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:padding="14dp"
                    android:src="@drawable/ic_chevron_right_custom"
                    app:tint="@android:color/white" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#14FFFFFF" />

            <!-- Clear Cache -->
            <RelativeLayout
                android:id="@+id/itemClearCache"
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/iconClearCache"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_centerVertical="true"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_red_close" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/iconClearCache"
                    android:layout_toStartOf="@id/arrowClearCache"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/clear_cache"
                        android:textColor="@android:color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/settings_cancel_desc"
                        android:textColor="#8A8A8A"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/arrowClearCache"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/round_dark_button_bg"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:padding="14dp"
                    android:src="@drawable/ic_chevron_right_custom"
                    app:tint="@android:color/white" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#14FFFFFF" />

            <!-- Terms & Conditions -->
            <RelativeLayout
                android:id="@+id/itemTerms"
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/iconTerms"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_centerVertical="true"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_wallet_custom"
                    app:tint="#63D8F2" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/iconTerms"
                    android:layout_toStartOf="@id/arrowTerms"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/terms_conditions"
                        android:textColor="@android:color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/settings_transaction_desc"
                        android:textColor="#8A8A8A"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/arrowTerms"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/round_dark_button_bg"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:padding="14dp"
                    android:src="@drawable/ic_chevron_right_custom"
                    app:tint="@android:color/white" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#14FFFFFF" />

            <!-- Contact us -->
            <RelativeLayout
                android:id="@+id/itemContact"
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/iconContact"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_centerVertical="true"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_teal_ticket" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/iconContact"
                    android:layout_toStartOf="@id/arrowContact"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/contact_us_star"
                        android:textColor="@android:color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/settings_coupon_desc"
                        android:textColor="#8A8A8A"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/arrowContact"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/round_dark_button_bg"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:padding="14dp"
                    android:src="@drawable/ic_chevron_right_custom"
                    app:tint="@android:color/white" />
            </RelativeLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>