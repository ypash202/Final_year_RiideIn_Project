<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.EnterRouteActivity">

    <ImageView
        android:id="@+id/mapBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/map_bg" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000" />

    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/round_dark_button_bg"
        android:contentDescription="@string/back"
        android:padding="12dp"
        android:src="@drawable/ic_back_custom"
        app:tint="@android:color/white" />

    <ImageButton
        android:id="@+id/closeButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="end"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="18dp"
        android:background="@drawable/round_dark_button_bg"
        android:contentDescription="@string/close"
        android:padding="12dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="@android:color/white" />

    <LinearLayout
        android:id="@+id/routePanel"
        android:layout_width="match_parent"
        android:layout_height="638dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="78dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/enter_route_panel_bg"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="24dp"
        android:paddingEnd="16dp"
        android:paddingBottom="20dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/enter_your_route"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <AutoCompleteTextView
            android:id="@+id/fromEditText"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/search_box_bg"
            android:completionThreshold="1"
            android:drawableStart="@drawable/dot"
            android:drawablePadding="10dp"
            android:dropDownWidth="match_parent"
            android:dropDownHeight="wrap_content"
            android:dropDownVerticalOffset="6dp"
            android:hint="@string/from"
            android:importantForAutofill="no"
            android:inputType="text"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:popupBackground="@android:color/white"
            android:textColor="@android:color/white"
            android:textColorHint="#8A8A8A"
            android:textSize="16sp"
            app:tint="#63B7C4" />

        <AutoCompleteTextView
            android:id="@+id/toEditText"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/search_box_bg"
            android:completionThreshold="1"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="10dp"
            android:dropDownWidth="match_parent"
            android:dropDownHeight="wrap_content"
            android:dropDownVerticalOffset="6dp"
            android:hint="@string/to"
            android:imeOptions="actionDone"
            android:importantForAutofill="no"
            android:inputType="text"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:popupBackground="@android:color/white"
            android:textColor="@android:color/white"
            android:textColorHint="#8A8A8A"
            android:textSize="16sp"
            app:tint="#63B7C4" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/nextButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:backgroundTint="#63C7D8"
            android:text="@string/next"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

    </LinearLayout>

</FrameLayout>