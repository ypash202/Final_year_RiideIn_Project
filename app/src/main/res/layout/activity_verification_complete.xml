<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="28dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="48dp">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true"
                android:background="@drawable/round_dark_button_bg"
                android:contentDescription="@string/back"
                android:padding="13dp"
                android:src="@drawable/ic_back_custom"
                app:tint="@android:color/white" />

            <ImageButton
                android:id="@+id/closeButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:background="@drawable/round_dark_button_bg"
                android:contentDescription="@string/close"
                android:padding="13dp"
                android:src="@drawable/ic_close_custom"
                app:tint="@android:color/white" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/checkIcon"
                android:layout_width="92dp"
                android:layout_height="92dp"
                android:contentDescription="@string/verification_complete"
                android:src="@drawable/ic_settings_blue_check" />

            <TextView
                android:id="@+id/titleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:gravity="center"
                android:text="@string/verification_complete"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/messageText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="@string/driver_verification_message"
                android:textColor="#B3B3B3"
                android:textSize="14sp" />
        </LinearLayout>

        <Button
            android:id="@+id/goOnlineButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="28dp"
            android:background="@drawable/driver_mode_button_bg"
            android:text="@string/go_to_login"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="17sp" />

    </LinearLayout>

</FrameLayout>