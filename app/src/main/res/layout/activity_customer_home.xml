<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.CustomerHomeActivity">

    <!-- Background map -->
    <ImageView
        android:id="@+id/mapBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/map_bg" />

    <!-- Dark overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000" />

    <!-- Back button -->
    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/round_dark_button_bg"
        android:contentDescription="Back"
        android:padding="10dp"
        android:src="@drawable/ic_back_custom"
        app:tint="@android:color/white" />

    <!-- Close button -->
    <ImageButton
        android:id="@+id/closeButton"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_gravity="end"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="18dp"
        android:background="@drawable/round_dark_button_bg"
        android:contentDescription="Close"
        android:padding="10dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="@android:color/white" />

    <!-- Top marker -->
    <FrameLayout
        android:id="@+id/topMarkerWrap"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="184dp"
        android:layout_marginTop="90dp"
        android:background="@drawable/marker_circle_bg">

        <ImageView
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:layout_gravity="center"
            android:rotation="15"
            android:src="@drawable/ic_send_custom"
            app:tint="#63B7C4" />
    </FrameLayout>

    <!-- Route line -->
    <ImageView
        android:id="@+id/routeLineImage"
        android:layout_width="92dp"
        android:layout_height="144dp"
        android:layout_marginStart="158dp"
        android:layout_marginTop="110dp"
        android:src="@drawable/route_line_overlay" />

    <!-- Bottom marker -->
    <FrameLayout
        android:id="@+id/bottomMarkerWrap"
        android:layout_width="62dp"
        android:layout_height="62dp"
        android:layout_marginStart="130dp"
        android:layout_marginTop="184dp"
        android:background="@drawable/marker_circle_bg">

        <View
            android:layout_width="11dp"
            android:layout_height="11dp"
            android:layout_gravity="center"
            android:background="@drawable/driver_inner_dot_bg" />
    </FrameLayout>

    <!-- Driver card -->
    <LinearLayout
        android:id="@+id/driverInfoCard"
        android:layout_width="145dp"
        android:layout_height="48dp"
        android:layout_marginStart="14dp"
        android:layout_marginTop="145dp"
        android:background="@drawable/round_dark_button_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp">

        <FrameLayout
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:background="@drawable/driver_dot_bg">

            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_gravity="center"
                android:background="@drawable/driver_inner_dot_bg" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="9dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pash"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Driver located near you"
                android:textColor="@android:color/white"
                android:textSize="8sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Send button -->
    <ImageButton
        android:id="@+id/locationButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="324dp"
        android:background="@drawable/round_dark_button_bg"
        android:contentDescription="Send"
        android:padding="10dp"
        android:rotation="-20"
        android:src="@drawable/ic_send_custom"
        app:tint="@android:color/white" />

    <!-- Bottom area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- White handle -->

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <View
            android:layout_width="32dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:background="#FFFFFF" />

        <!-- Bottom panel -->
        <LinearLayout
            android:id="@+id/bottomPanel"
            android:layout_width="357dp"
            android:layout_height="wrap_content"
            android:background="@drawable/customer_bottom_panel_bg"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/motoOption"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/bike" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Moto"
                        android:textColor="@android:color/white"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cabOption"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/car" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Cab"
                        android:textColor="@android:color/white"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/deliveryOption"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/delivery" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Delivery"
                        android:textColor="@android:color/white"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <EditText
                android:id="@+id/searchBox"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/search_box_bg"
                android:clickable="true"
                android:cursorVisible="false"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="10dp"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:hint="Where &amp; how much?"
                android:inputType="none"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@android:color/white"
                android:textColorHint="#8A8A8A"
                app:tint="#63B7C4" />

            <Button
                android:id="@+id/promoButton"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="#63B7C4"
                android:text="Apply Promo Code"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>