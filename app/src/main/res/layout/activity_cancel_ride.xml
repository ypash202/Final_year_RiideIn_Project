<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.CancelRideActivity">

    <ImageView
        android:id="@+id/mapBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/map_bg" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000" />

    <ImageButton
        android:id="@+id/backButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/round_dark_button_bg"
        android:contentDescription="@string/back"
        android:padding="10dp"
        android:src="@drawable/ic_back_custom"
        app:tint="@android:color/white" />

    <ImageButton
        android:id="@+id/closeButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="end"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="18dp"
        android:background="@drawable/round_dark_button_bg"
        android:contentDescription="@string/close"
        android:padding="10dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="@android:color/white" />

    <LinearLayout
        android:id="@+id/trackingPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/tracking_bottom_sheet_bg"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="22dp"
        android:paddingEnd="18dp"
        android:paddingBottom="22dp">

        <TextView
            android:id="@+id/arrivalTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/driver_arriving_1_min"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/driverProfileImage"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@string/driver_profile"
                android:src="@drawable/profile1" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/driverName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/driver_name"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/vehicleName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/vehicle_name"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ImageView
                android:id="@+id/vehicleImage"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:contentDescription="@string/vehicle_image"
                android:src="@drawable/bike" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:background="@drawable/cancel_reason_panel_bg"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="18dp">

            <TextView
                android:id="@+id/reasonTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/why_cancel"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/cancelReasonGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/reason1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:button="@null"
                    android:maxWidth="260dp"
                    android:minHeight="48dp"
                    android:minWidth="48dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:singleLine="false"
                    android:text="@string/reason_no_need_ride"
                    android:textColor="@android:color/white"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/reason2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:button="@null"
                    android:maxWidth="260dp"
                    android:minHeight="48dp"
                    android:minWidth="48dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:singleLine="false"
                    android:text="@string/reason_need_changes"
                    android:textColor="@android:color/white"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/reason3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:button="@null"
                    android:maxWidth="260dp"
                    android:minHeight="48dp"
                    android:minWidth="48dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:singleLine="false"
                    android:text="@string/reason_driver_late"
                    android:textColor="@android:color/white"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/reason4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:button="@null"
                    android:maxWidth="260dp"
                    android:minHeight="48dp"
                    android:minWidth="48dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:singleLine="false"
                    android:text="@string/reason_driver_cancel"
                    android:textColor="@android:color/white"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/reason5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:button="@null"
                    android:maxWidth="260dp"
                    android:minHeight="48dp"
                    android:minWidth="48dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:singleLine="false"
                    android:text="@string/reason_app_issue"
                    android:textColor="@android:color/white"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/reason6"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:button="@null"
                    android:maxWidth="260dp"
                    android:minHeight="48dp"
                    android:minWidth="48dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:singleLine="false"
                    android:text="@string/reason_other"
                    android:textColor="@android:color/white"
                    android:textSize="14sp" />
            </RadioGroup>

            <Button
                android:id="@+id/continueRideButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="18dp"
                android:maxWidth="260dp"
                android:minHeight="48dp"
                android:background="@drawable/continue_ride_button_bg"
                android:text="@string/cancel_ride_button"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>