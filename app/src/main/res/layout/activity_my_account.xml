<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.MyAccountActivity">

    <ImageView
        android:id="@+id/mapBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/map_bg" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="34dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="@drawable/round_dark_button_bg"
                android:contentDescription="@string/back"
                android:padding="12dp"
                android:src="@drawable/ic_back_custom"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="My Account"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/closeButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/round_dark_button_bg"
                android:contentDescription="@string/close"
                android:padding="13dp"
                android:src="@drawable/ic_close_custom"
                app:tint="@android:color/white" />
        </RelativeLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="false"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="22dp" />

                <LinearLayout
                    android:id="@+id/profileHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingBottom="16dp">

                    <ImageView
                        android:id="@+id/profileImage"
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:background="@drawable/profile_circle_border"
                        android:contentDescription="Profile picture"
                        android:padding="3dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/profile2" />

                    <TextView
                        android:id="@+id/changePhotoButton"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/round_dark_button_bg"
                        android:gravity="center"
                        android:minWidth="76dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="Change"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/profileNameText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="User"
                        android:textColor="@android:color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/profileRoleText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="Customer"
                        android:textColor="#B0B0B0"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/accountPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#D9000000"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:id="@+id/itemLevel"
                        android:layout_width="match_parent"
                        android:layout_height="82dp"
                        android:paddingStart="18dp"
                        android:paddingTop="14dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="14dp">

                        <ImageView
                            android:id="@+id/iconLevel"
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:layout_centerVertical="true"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_settings_blue_check" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="14dp"
                            android:layout_toEndOf="@id/iconLevel"
                            android:layout_toStartOf="@id/arrowLevel"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Level"
                                android:textColor="@android:color/white"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/levelValueText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Customer"
                                android:textColor="#8A8A8A"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <ImageButton
                            android:id="@+id/arrowLevel"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/round_dark_button_bg"
                            android:contentDescription="@null"
                            android:importantForAccessibility="no"
                            android:padding="14dp"
                            android:src="@drawable/ic_chevron_right_custom"
                            app:tint="@android:color/white" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#14FFFFFF" />

                    <RelativeLayout
                        android:id="@+id/itemName"
                        android:layout_width="match_parent"
                        android:layout_height="82dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingStart="18dp"
                        android:paddingTop="14dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="14dp">

                        <ImageView
                            android:id="@+id/iconName"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_centerVertical="true"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_settings_teal_ticket" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="14dp"
                            android:layout_toEndOf="@id/iconName"
                            android:layout_toStartOf="@id/arrowName"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Name"
                                android:textColor="@android:color/white"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/nameValueText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="User"
                                android:textColor="#8A8A8A"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <ImageButton
                            android:id="@+id/arrowName"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/round_dark_button_bg"
                            android:contentDescription="@null"
                            android:importantForAccessibility="no"
                            android:padding="14dp"
                            android:src="@drawable/ic_chevron_right_custom"
                            app:tint="@android:color/white" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#14FFFFFF" />

                    <RelativeLayout
                        android:id="@+id/itemPhoneNumber"
                        android:layout_width="match_parent"
                        android:layout_height="82dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingStart="18dp"
                        android:paddingTop="14dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="14dp">

                        <ImageView
                            android:id="@+id/iconPhoneNumber"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_centerVertical="true"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_settings_teal_ticket" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="14dp"
                            android:layout_toEndOf="@id/iconPhoneNumber"
                            android:layout_toStartOf="@id/phoneLockText"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Phone Number*"
                                android:textColor="@android:color/white"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/phoneValueText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="Not added"
                                android:textColor="#8A8A8A"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/phoneLockText"
                            android:layout_width="70dp"
                            android:layout_height="42dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/round_dark_button_bg"
                            android:gravity="center"
                            android:text="Locked"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#14FFFFFF" />

                    <RelativeLayout
                        android:id="@+id/itemEmail"
                        android:layout_width="match_parent"
                        android:layout_height="82dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingStart="18dp"
                        android:paddingTop="14dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="14dp">

                        <ImageView
                            android:id="@+id/iconEmail"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_centerVertical="true"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_settings_teal_ticket" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="14dp"
                            android:layout_toEndOf="@id/iconEmail"
                            android:layout_toStartOf="@id/arrowEmail"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Email"
                                android:textColor="@android:color/white"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/emailValueText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="Not added"
                                android:textColor="#8A8A8A"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <ImageButton
                            android:id="@+id/arrowEmail"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/round_dark_button_bg"
                            android:contentDescription="@null"
                            android:importantForAccessibility="no"
                            android:padding="14dp"
                            android:src="@drawable/ic_chevron_right_custom"
                            app:tint="@android:color/white" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#14FFFFFF" />

                    <RelativeLayout
                        android:id="@+id/itemBirthday"
                        android:layout_width="match_parent"
                        android:layout_height="82dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingStart="18dp"
                        android:paddingTop="14dp"
                        android:paddingEnd="18dp"
                        android:paddingBottom="14dp">

                        <ImageView
                            android:id="@+id/iconBirthday"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_centerVertical="true"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_wallet_custom"
                            app:tint="#63D8F2" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="14dp"
                            android:layout_toEndOf="@id/iconBirthday"
                            android:layout_toStartOf="@id/arrowBirthday"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Birthday"
                                android:textColor="@android:color/white"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/birthdayValueText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="Not added"
                                android:textColor="#8A8A8A"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <ImageButton
                            android:id="@+id/arrowBirthday"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/round_dark_button_bg"
                            android:contentDescription="@null"
                            android:importantForAccessibility="no"
                            android:padding="14dp"
                            android:src="@drawable/ic_chevron_right_custom"
                            app:tint="@android:color/white" />
                    </RelativeLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>