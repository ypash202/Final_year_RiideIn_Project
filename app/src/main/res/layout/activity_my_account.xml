<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.MyAccountActivity">

    <!-- Background -->
    <ImageView
        android:id="@+id/mapBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/map_bg" />

    <!-- Dark overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000" />

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="34dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <!-- Top bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="@drawable/round_dark_button_bg"
                android:contentDescription="@string/back"
                android:padding="12dp"
                android:src="@drawable/ic_back_custom"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/my_account"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/deleteButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/round_dark_button_bg"
                android:contentDescription="@string/delete"
                android:padding="12dp"
                android:src="@drawable/ic_delete_custom"
                app:tint="@android:color/white" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="42dp" />

        <!-- Account panel -->
        <LinearLayout
            android:id="@+id/accountPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#D9000000"
            android:orientation="vertical">

            <!-- Level -->
            <RelativeLayout
                android:id="@+id/itemLevel"
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/iconLevel"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:layout_centerVertical="true"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_blue_check" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/iconLevel"
                    android:layout_toStartOf="@id/arrowLevel"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/level"
                        android:textColor="@android:color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/gold_member"
                        android:textColor="#8A8A8A"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/arrowLevel"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/round_dark_button_bg"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:padding="14dp"
                    android:src="@drawable/ic_chevron_right_custom"
                    app:tint="@android:color/white" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#14FFFFFF" />

            <!-- Name -->
            <RelativeLayout
                android:id="@+id/itemName"
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/iconName"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_centerVertical="true"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_teal_ticket" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/iconName"
                    android:layout_toStartOf="@id/arrowName"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/name"
                        android:textColor="@android:color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/account_name_desc"
                        android:textColor="#8A8A8A"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/arrowName"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/round_dark_button_bg"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:padding="14dp"
                    android:src="@drawable/ic_chevron_right_custom"
                    app:tint="@android:color/white" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#14FFFFFF" />

            <!-- Phone Number -->
            <RelativeLayout
                android:id="@+id/itemPhoneNumber"
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/iconPhoneNumber"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_centerVertical="true"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_teal_ticket" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/iconPhoneNumber"
                    android:layout_toStartOf="@id/arrowPhoneNumber"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/phone_number_star"
                        android:textColor="@android:color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/account_phone_desc"
                        android:textColor="#8A8A8A"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/arrowPhoneNumber"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/round_dark_button_bg"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:padding="14dp"
                    android:src="@drawable/ic_chevron_right_custom"
                    app:tint="@android:color/white" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#14FFFFFF" />

            <!-- Email -->
            <RelativeLayout
                android:id="@+id/itemEmail"
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/iconEmail"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_centerVertical="true"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_teal_ticket" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/iconEmail"
                    android:layout_toStartOf="@id/arrowEmail"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/email"
                        android:textColor="@android:color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/account_email_desc"
                        android:textColor="#8A8A8A"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/arrowEmail"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/round_dark_button_bg"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:padding="14dp"
                    android:src="@drawable/ic_chevron_right_custom"
                    app:tint="@android:color/white" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#14FFFFFF" />

            <!-- Gender -->
            <RelativeLayout
                android:id="@+id/itemGender"
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/iconGender"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:layout_centerVertical="true"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_settings_red_close" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/iconGender"
                    android:layout_toStartOf="@id/arrowGender"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/gender"
                        android:textColor="@android:color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/account_gender_desc"
                        android:textColor="#8A8A8A"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/arrowGender"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/round_dark_button_bg"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:padding="14dp"
                    android:src="@drawable/ic_chevron_right_custom"
                    app:tint="@android:color/white" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#14FFFFFF" />

            <!-- Birthday -->
            <RelativeLayout
                android:id="@+id/itemBirthday"
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:paddingStart="18dp"
                android:paddingTop="16dp"
                android:paddingEnd="18dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:id="@+id/iconBirthday"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_centerVertical="true"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_wallet_custom"
                    app:tint="#63D8F2" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/iconBirthday"
                    android:layout_toStartOf="@id/arrowBirthday"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/birthday"
                        android:textColor="@android:color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/account_birthday_desc"
                        android:textColor="#8A8A8A"
                        android:textSize="13sp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/arrowBirthday"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/round_dark_button_bg"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:padding="14dp"
                    android:src="@drawable/ic_chevron_right_custom"
                    app:tint="@android:color/white" />
            </RelativeLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>